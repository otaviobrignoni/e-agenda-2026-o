@model (Guid id, bool mostrarDetalhes, bool mostrarExcluir)
<div class="mt-auto d-flex flex-wrap gap-2 justify-content-end">
    @if (Model.mostrarDetalhes)
    {
        <a class="btn btn-outline-primary btn-sm rounded-pill" asp-action="Detalhes" asp-route-id="@Model.id" aria-label="Detalhes" title="Detalhes">
            <i class="bi bi-eye" aria-hidden="true"></i>
        </a>
    }
    <a class="btn btn-outline-secondary btn-sm rounded-pill" asp-action="Editar" asp-route-id="@Model.id" aria-label="Editar" title="Editar">
        <i class="bi bi-pencil" aria-hidden="true"></i>
    </a>
    @if (Model.mostrarExcluir)
    {
        <a class="btn btn-outline-danger btn-sm rounded-pill" asp-action="Excluir" asp-route-id="@Model.id" aria-label="Excluir" title="Excluir">
            <i class="bi bi-trash" aria-hidden="true"></i>
        </a>
    }
</div>
