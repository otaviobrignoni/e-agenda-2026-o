@model FormSelectViewModel
@{
    var selectedValues = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

    if (Model.Value is not null)
    {
        selectedValues.Add(Model.Value.ToString()!);

        if (Model.Value is Enum enumValue)
            selectedValues.Add(Convert.ToInt64(enumValue).ToString());
    }
}
<div class="form-group mb-3">
    <label for="@Model.Name" class="form-label fw-semibold text-primary text-uppercase small">@Model.Label</label>
    <select id="@Model.Name" name="@Model.Name" class="form-select">
        @if (Model.Placeholder is not null)
        {
            <option value="">@Model.Placeholder</option>
        }
        @foreach (var option in Model.Options)
        {
            if (option.Selected || selectedValues.Contains(option.Value))
            {
                <option value="@option.Value" selected>@option.Text</option>
            }
            else
            {
                <option value="@option.Value">@option.Text</option>
            }
        }
    </select>
</div>
@Html.ValidationMessage(Model.Name, "", new { @class = "text-danger small fw-semibold field-validation-error" })
