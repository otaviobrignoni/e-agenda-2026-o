@{
    ViewBag.Titulo = "Listagem de Tarefas";
}
@model List<MostrarTarefaViewModel>

<partial name="_BotaoCadastrar" />

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <partial name="_Alerta" model="@new AlertaViewModel(mensagemErro, true)" />
}
@if (Model.Count == 0)
{
    <partial name="_Alerta" model="@(new AlertaViewModel("Nenhuma tarefa cadastrada."))" />
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var t in Model)
        {
            var percentualConcluido = Math.Clamp(t.PercentualConcluido * 100, 0, 100);

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm border-1 rounded-4">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@t.Titulo</h5>
                            <span class="badge rounded-pill @t.ClassePrioridade">
                                @t.Prioridade
                            </span>
                        </div>
                        <p class="text-muted small mb-3"> Criada em @t.DataCriacao.ToShortDateString() </p>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>
                                    Progresso @if (t.EstaConcluida && t.DataConclusao is not null)
                                    {
                                        <span class="text-muted small text-start"> Concluida em @t.DataConclusao.Value.ToShortDateString() </span>
                                    }
                                </span>
                                <span>@percentualConcluido.ToString("0", CultureInfo.CurrentCulture)%</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar" role="progressbar" style="width: @percentualConcluido.ToString("0.##", CultureInfo.InvariantCulture)%" aria-valuenow="@percentualConcluido.ToString("0.##", CultureInfo.InvariantCulture)" aria-valuemin="0" aria-valuemax="100"> </div>
                            </div>
                        </div>
                        <partial name="_CardAcoes" model="(t.Id, true, true)" />
                    </div>
                </div>
            </div>
        }
    </div>
}
